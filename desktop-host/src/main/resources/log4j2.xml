<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Appenders>
        <Console name="SysOut" target="SYSTEM_OUT">
            <PatternLayout
                    pattern="%style{[%d{HH:mm:ss}]}{blue} %highlight{[%t/%level]}{FATAL=red, ERROR=red, WARN=yellow, INFO=green, DEBUG=green, TRACE=blue} %style{(%c{1})}{cyan} %highlight{%msg%n}{FATAL=red, ERROR=red, WARN=normal, INFO=normal, DEBUG=normal, TRACE=normal}"/>
        </Console>
        <RollingRandomAccessFile name="File" fileName="${sys:qplayer.logs:-logs}/latest.log" filePattern="${sys:qplayer.logs:-logs}/%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout pattern="[%d{HH:mm:ss}] [%t/%level] %msg%n"/>
            <Policies>
                <!-- OnStartupTriggeringPolicy is omitted on purpose: in the native
                     image it reflectively loads java.lang.management.ManagementFactory
                     (absent from the image) and logs a startup ERROR. Time-based daily
                     rollover is enough. -->
                <TimeBasedTriggeringPolicy/>
            </Policies>
        </RollingRandomAccessFile>
    </Appenders>
    <Loggers>
        <!-- No MarkerFilter here: its @PluginFactory isn't reachable in the native
             image (logs "No factory method found"), and nothing emits the
             NETWORK_PACKETS marker anyway. -->
        <Root level="info">
            <AppenderRef ref="SysOut"/>
            <AppenderRef ref="File"/>
        </Root>
    </Loggers>
</Configuration>
