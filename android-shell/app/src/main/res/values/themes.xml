<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- No ActionBar (drops the "qplayer" title bar); status + navigation bars
         painted with the app surface colour so they stop reading as black
         strips above/below the content. -->
    <style name="AppTheme" parent="@android:style/Theme.DeviceDefault.NoActionBar">
        <item name="android:windowBackground">@color/app_surface</item>
        <item name="android:statusBarColor">@color/app_surface</item>
        <item name="android:navigationBarColor">@color/app_surface</item>
    </style>
</resources>
